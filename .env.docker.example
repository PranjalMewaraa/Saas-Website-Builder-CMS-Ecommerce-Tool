NODE_ENV=production

# Public app URLs
ADMIN_BASE_URL=http://localhost:3000
STOREFRONT_BASE_URL=http://localhost:3002
ADMIN_PORT=3000
STOREFRONT_PORT=3002

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=saasbuilder

# MySQL (docker-compose will create this locally)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=saas_builder
MYSQL_USER=app
MYSQL_PASSWORD=app_password
MYSQL_EXPOSE_PORT=3306

# Assets / CDN
S3_ENDPOINT=
S3_ENDPOINT2=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
CDN_BASE_URL=

# Storefront fallback
DEFAULT_SITE_HANDLE=nikee
